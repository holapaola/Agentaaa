# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (for AI content generation — Agents 2 & 3)
VITE_OPENAI_API_KEY=sk-...

# Perplexity (for Agent 1 live web research — get key at https://www.perplexity.ai/settings/api)
VITE_PERPLEXITY_API_KEY=pplx-...

# Social Media APIs
VITE_TWITTER_API_KEY=your-twitter-api-key
VITE_INSTAGRAM_API_KEY=your-instagram-api-key
VITE_LINKEDIN_API_KEY=your-linkedin-api-key

# Stripe (get from https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe secret keys — used in Supabase Edge Functions only (never expose to frontend)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in Stripe dashboard then paste IDs here
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_ENTERPRISE=price_...
